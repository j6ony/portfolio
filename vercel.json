{
    "buildCommand":  "pnpm run build",
    "outputDirectory":  "dist",
    "framework":  "vite",
    "rewrites":  [
                     {
                         "destination":  "https://wdefang3.pythonanywhere.com/admin/$1",
                         "source":  "/admin/(.*)"
                     },
                     {
                         "source":  "/api/(.*)",
                         "destination":  "https://wdefang3.pythonanywhere.com/api/$1"
                     },
                     {
                         "source":  "/(.*)",
                         "destination":  "/index.html"
                     }
                 ],
    "headers":  [
                    {
                        "source":  "/(.*)",
                        "headers":  [
                                        {
                                            "key":  "X-Content-Type-Options",
                                            "value":  "nosniff"
                                        },
                                        {
                                            "key":  "X-Frame-Options",
                                            "value":  "DENY"
                                        },
                                        {
                                            "key":  "X-XSS-Protection",
                                            "value":  "1; mode=block"
                                        }
                                    ]
                    },
                    {
                        "source":  "/assets/(.*)",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "public, max-age=31536000, immutable"
                                        }
                                    ]
                    }
                ]
}
